        "        for level, title in headings[:10]:\n",
        "            indent = \"  \" * (len(level) - 1)\n",
        "            print(f\"{indent}{level} {title}\")\n",
        "\n",
        "    # Find formulas (MinerU converts formulas to LaTeX)\n",
