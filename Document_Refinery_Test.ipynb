        "## Run MinerU with Correct Syntax\n",
        "\n",
        "from pathlib import Path\n",
        "import subprocess\n",
        "import time\n",
        "\n",
        "pdf_path = Path(\"/content/data/class_b/2018_Audited_Financial_Statement_Report.pdf\")\n",
        "output_dir = Path(\"/content/outputs/mineru_final\")\n",
        "output_dir.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "print(f\"📄 Processing: {pdf_path.name}\")\n",
        "print(f\"📁 Output directory: {output_dir}\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "start_time = time.time()\n",
        "\n",
        "# Use the correct syntax with required -p and -o options\n",
        "# Let's try different methods to see which works best\n",
        "\n",
        "methods = [\n",
        "    # Method auto (default)\n",
        "    {\n",
        "        \"name\": \"Auto method\",\n",
        "        \"cmd\": f\"mineru -p {pdf_path} -o {output_dir} -m auto\"\n",
        "    },\n",
        "    # Method txt (for digital PDFs)\n",
        "    {\n",
        "        \"name\": \"Text method (for digital PDFs)\",\n",
        "        \"cmd\": f\"mineru -p {pdf_path} -o {output_dir} -m txt\"\n",
        "    },\n",
        "    # Method ocr (for scanned PDFs)\n",
        "    {\n",
        "        \"name\": \"OCR method (for scanned PDFs)\",\n",
        "        \"cmd\": f\"mineru -p {pdf_path} -o {output_dir} -m ocr\"\n",
        "    },\n",
        "    # With table parsing enabled\n",
        "    {\n",
        "        \"name\": \"Auto with tables\",\n",
        "        \"cmd\": f\"mineru -p {pdf_path} -o {output_dir} -m auto -t True\"\n",
        "    },\n",
        "    # With specific backend\n",
        "    {\n",
        "        \"name\": \"Pipeline backend\",\n",
        "        \"cmd\": f\"mineru -p {pdf_path} -o {output_dir} -m auto -b pipeline\"\n",
        "    }\n",
        "]\n",
        "\n",
        "for i, method in enumerate(methods, 1):\n",
        "    print(f\"\\n{i}. {method['name']}\")\n",
        "    print(f\"   Command: {method['cmd']}\")\n",
        "    print(\"-\" * 40)\n",
        "\n",
        "    try:\n",
        "        result = subprocess.run(method['cmd'], shell=True, capture_output=True, text=True, timeout=600)\n",
        "\n",
        "        if result.returncode == 0:\n",
        "            print(f\"✅ SUCCESS!\")\n",
        "            if result.stdout:\n",
        "                print(\"Output:\", result.stdout[:300])\n",
        "\n",
        "            # Check for generated files\n",
        "            print(\"\\n🔍 Generated files:\")\n",
        "            files = list(output_dir.rglob(\"*\"))\n",
        "            if files:\n",
        "                for f in files:\n",
        "                    if f.is_file():\n",
        "                        size_kb = f.stat().st_size / 1024\n",
        "                        print(f\"  - {f.relative_to(output_dir)} ({size_kb:.1f} KB)\")\n",
        "\n",
        "                        # If it's a markdown file, show preview\n",
        "                        if f.suffix.lower() == '.md':\n",
        "                            print(f\"\\n📝 Markdown file found: {f.name}\")\n",
        "                            try:\n",
        "                                with open(f, 'r', encoding='utf-8') as md:\n",
        "                                    content = md.read(500)\n",
        "                                    print(\"Preview:\")\n",
        "                                    print(\"-\" * 40)\n",
        "                                    print(content)\n",
        "                                    print(\"-\" * 40)\n",
        "                            except Exception as e:\n",
        "                                print(f\"Could not read markdown: {e}\")\n",
        "            else:\n",
        "                print(\"  No files generated yet\")\n",
        "\n",
        "            # If successful, we can break here\n",
        "            print(f\"\\n⏱️ Time: {time.time() - start_time:.2f} seconds\")\n",
        "            break\n",
        "        else:\n",
        "            print(f\"❌ Failed with error code {result.returncode}\")\n",
        "            if result.stderr:\n",
        "                print(f\"Error: {result.stderr[:300]}\")\n",
        "\n",
        "    except subprocess.TimeoutExpired:\n",
        "        print(\"⏰ Command timed out after 10 minutes\")\n",
        "    except Exception as e:\n",
        "        print(f\"❌ Exception: {e}\")\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(f\"⏱️ Total time: {time.time() - start_time:.2f} seconds\")"
      ]
    },
