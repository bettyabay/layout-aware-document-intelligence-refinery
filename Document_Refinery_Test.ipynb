        "## Configure Docling for Faster Processing\n",
        "\n",
        "from docling.document_converter import DocumentConverter\n",
        "from docling.datamodel.pipeline_options import PdfPipelineOptions\n",
        "from docling.datamodel.base_models import InputFormat\n",
        "\n",
        "# Optional: use the faster v2 backend if available\n",
        "try:\n",
        "    from docling.backend.docling_parse_v2_backend import DoclingParseV2DocumentBackend\n",
        "    BACKEND = DoclingParseV2DocumentBackend\n",
        "    print(\"✅ Using DoclingParseV2DocumentBackend\")\n",
        "except Exception:\n",
        "    from docling.backend.pypdfium2_backend import PyPdfiumDocumentBackend\n",
        "    BACKEND = PyPdfiumDocumentBackend\n",
        "    print(\"✅ Using PyPdfiumDocumentBackend\")\n",
        "\n",
        "\n",
        "def create_fast_docling_converter(use_ocr: bool) -> DocumentConverter:\n",
        "    \"\"\"Create a Docling converter tuned for speed on digital PDFs.\n",
        "\n",
        "    Args:\n",
        "        use_ocr: Whether to enable OCR (True only for scanned-image PDFs).\n",
        "    \"\"\"\n",
        "    # Create pipeline options\n",
        "    pipeline_options = PdfPipelineOptions()\n",
        "    pipeline_options.do_ocr = use_ocr           # True only for scanned docs\n",
        "    pipeline_options.do_table_structure = True  # Keep if you need tables\n",
        "\n",
        "    # For Docling versions that don't accept pipeline_options in constructor,\n",
        "    # we need to create the converter first, then set the pipeline options\n",
        "    converter = DocumentConverter()\n",
        "\n",
        "    # Set the backend if possible\n",
        "    try:\n",
        "        # Different Docling versions have different ways to set the backend\n",
        "        if hasattr(converter, 'set_backend'):\n",
        "            converter.set_backend(BACKEND)\n",
        "        elif hasattr(converter, '_backend'):\n",
        "            converter._backend = BACKEND\n",
        "    except Exception as e:\n",
        "        print(f\"Note: Could not set backend: {e}\")\n",
        "\n",
        "    # Set pipeline options if possible\n",
        "    try:\n",
        "        if hasattr(converter, 'set_pipeline_options'):\n",
        "            converter.set_pipeline_options(pipeline_options)\n",
        "        elif hasattr(converter, 'pipeline_options'):\n",
        "            converter.pipeline_options = pipeline_options\n",
        "    except Exception as e:\n",
        "        print(f\"Note: Could not set pipeline options: {e}\")\n",
        "\n",
        "    return converter\n",
        "\n",
        "\n",
        "# Check if profile exists\n",
        "if 'profile' in globals() and profile:\n",
        "    # Decide based on triage profile\n",
        "    use_ocr = profile.origin_type == \"scanned_image\"\n",
        "    print(f\"\\n📄 Document origin: {profile.origin_type}\")\n",
        "    print(f\"  Using OCR: {use_ocr}\")\n",
        "\n",
        "    fast_converter = create_fast_docling_converter(use_ocr=use_ocr)\n",
        "\n",
        "    # Override the internal converter of LayoutExtractor\n",
        "    if 'layout_extractor' in globals() and layout_extractor:\n",
        "        try:\n",
        "            # Try different ways to set the converter\n",
        "            if hasattr(layout_extractor, '_converter'):\n",
        "                layout_extractor._converter = fast_converter\n",
        "                print(\"✅ Successfully overrode LayoutExtractor converter\")\n",
        "            elif hasattr(layout_extractor, 'converter'):\n",
        "                layout_extractor.converter = fast_converter\n",
        "                print(\"✅ Successfully overrode LayoutExtractor converter\")\n",
        "            else:\n",
        "                print(\"⚠️ Could not find converter attribute in LayoutExtractor\")\n",
        "        except Exception as e:\n",
        "            print(f\"⚠️ Error overriding converter: {e}\")\n",
        "\n",
        "    print(f\"\\n🚀 Using Docling with do_ocr={use_ocr}\")\n",
        "else:\n",
        "    print(\"⚠️ No profile found. Run the Triage cell first.\")"
      ]
