      "source": [
        "# Cell 6: Run Vision Extraction (with Markdown Saving)\n",
        "\n",
        "import time\n",
        "from pathlib import Path\n",
        "import time\n",
        "import json\n",
        "\n",
        "if pdf_path is None:\n",
        "    print(\"❌ No document selected\")\n",
        "elif 'skip_extraction' in locals() and skip_extraction:\n",
        "    print(\"⏭️ Skipping extraction (cancelled by user)\")\n",
        "    extracted = None\n",
        "else:\n",
        "    print(\"📄 Extracting with VisionExtractor (OpenRouter)...\")\n",
        "    print(f\"   Model: {config['model']}\")\n",
        "    if config['test_mode']:\n",
        "        print(f\"   Test mode: Processing first {config['max_pages']} pages only\")\n",
        "\n",
        "    if config['cost_per_1k'] == 0:\n",
        "        print(\"   🆓 Using FREE model - no cost!\")\n",
        "        print(\"   ⚠️ Free models have rate limits: 20 requests/minute, 50-200 requests/day \")\n",
        "        print(\"   If you hit rate limits, wait a few minutes and try again\\n\")\n",
        "\n",
        "    print(\"   This may take several minutes...\\n\")\n",
        "\n",
        "    start_time = time.time()\n",
        "\n",
        "    try:\n",
        "        # Note: This assumes VisionExtractor accepts a max_pages parameter\n",
        "        # If not, you may need to modify the VisionExtractor class\n",
        "        if config['test_mode'] and hasattr(vision_extractor, 'extract_with_page_limit'):\n",
        "            extracted = vision_extractor.extract_with_page_limit(str(pdf_path), config['max_pages'])\n",
        "        else:\n",
        "            # For now, process full document\n",
        "            extracted = vision_extractor.extract(str(pdf_path))\n",
        "\n",
        "        elapsed = time.time() - start_time\n",
        "        print(f\"\\n✓ Extraction completed in {elapsed:.2f} seconds ({elapsed/60:.1f} minutes)\")\n",
        "\n",
        "        print(\"\\n📊 Extraction Summary:\")\n",
        "        print(f\"  - Text Blocks: {len(extracted.text_blocks):,}\")\n",
        "        print(f\"  - Tables: {len(extracted.tables)}\")\n",
        "        print(f\"  - Figures: {len(extracted.figures)}\")\n",
        "\n",
        "        print(\"\\n💰 Budget Usage:\")\n",
        "        if config['cost_per_1k'] == 0:\n",
        "            print(f\"  - Total Cost: $0.00 (FREE model)\")\n",
        "        else:\n",
        "            print(f\"  - Total Cost: ${vision_extractor.budget.total_cost_usd:.4f}\")\n",
        "            print(f\"  - Remaining Budget: ${vision_extractor.budget.remaining_budget_usd:.4f}\")\n",
        "\n",
        "        # Create output directory\n",
        "        output_dir = Path(\"/content/outputs/vision_extraction\")\n",
        "        output_dir.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "        # Create a subfolder for this document with timestamp\n",
        "        timestamp = time.strftime(\"%Y%m%d_%H%M%S\")\n",
        "        doc_output_dir = output_dir / f\"{pdf_path.stem}_{timestamp}\"\n",
        "        doc_output_dir.mkdir(exist_ok=True)\n",
        "\n",
        "        # ============ SAVE MARKDOWN ============\n",
        "        print(\"\\n📝 Saving Markdown output...\")\n",
        "\n",
        "        # Method 1: Try to get markdown from extracted document\n",
        "        markdown_content = None\n",
        "\n",
        "        # Check if extracted has a to_markdown method\n",
        "        if hasattr(extracted, 'to_markdown'):\n",
        "            markdown_content = extracted.to_markdown()\n",
        "            print(\"  ✅ Using extracted.to_markdown()\")\n",
        "        elif hasattr(extracted, 'export_to_markdown'):\n",
        "            markdown_content = extracted.export_to_markdown()\n",
        "            print(\"  ✅ Using extracted.export_to_markdown()\")\n",
        "        elif hasattr(extracted, 'markdown'):\n",
        "            markdown_content = extracted.markdown\n",
        "            print(\"  ✅ Using extracted.markdown attribute\")\n",
        "        else:\n",
        "            # Build markdown manually from components\n",
        "            print(\"  ⚠️ Building markdown from components...\")\n",
        "            md_lines = []\n",
        "            md_lines.append(f\"# {pdf_path.stem}\\n\")\n",
        "            md_lines.append(f\"*Extracted with {config['model']}*\\n\")\n",
        "            md_lines.append(f\"*Date: {time.strftime('%Y-%m-%d %H:%M:%S')}*\\n\")\n",
        "            md_lines.append(\"---\\n\")\n",
        "\n",
        "            # Add text blocks in reading order\n",
        "            if hasattr(extracted, 'reading_order') and extracted.reading_order:\n",
        "                md_lines.append(\"## Content\\n\")\n",
        "                for item_id in extracted.reading_order:\n",
        "                    # Find the corresponding item\n",
        "                    for block in extracted.text_blocks:\n",
        "                        if block.id == item_id:\n",
        "                            md_lines.append(block.content + \"\\n\\n\")\n",
        "                            break\n",
        "                    for table in extracted.tables:\n",
        "                        if table.id == item_id:\n",
        "                            md_lines.append(\"### Table\\n\")\n",
        "                            if hasattr(table, 'to_markdown'):\n",
        "                                md_lines.append(table.to_markdown() + \"\\n\\n\")\n",
        "                            break\n",
        "                    for fig in extracted.figures:\n",
        "                        if fig.id == item_id:\n",
        "                            md_lines.append(\"### Figure\\n\")\n",
        "                            if fig.caption:\n",
        "                                md_lines.append(f\"*{fig.caption}*\\n\\n\")\n",
        "                            break\n",
        "            else:\n",
        "                # Just add all text blocks\n",
        "                md_lines.append(\"## Content\\n\")\n",
        "                for block in extracted.text_blocks:\n",
        "                    md_lines.append(block.content + \"\\n\\n\")\n",
        "\n",
        "            markdown_content = \"\".join(md_lines)\n",
        "\n",
        "        # Save markdown if we have content\n",
        "        if markdown_content:\n",
        "            markdown_path = doc_output_dir / f\"{pdf_path.stem}_vision.md\"\n",
        "            with open(markdown_path, 'w', encoding='utf-8') as f:\n",
        "                f.write(markdown_content)\n",
        "            print(f\"  ✅ Markdown saved to: {markdown_path}\")\n",
        "            print(f\"     Size: {len(markdown_content):,} characters\")\n",
        "            print(f\"     Lines: {len(markdown_content.splitlines()):,}\")\n",
        "\n",
        "            # Show preview\n",
        "            print(\"\\n📄 Markdown Preview (first 500 characters):\")\n",
        "            print(\"-\" * 60)\n",
        "            print(markdown_content[:500])\n",
        "            print(\"...\" if len(markdown_content) > 500 else \"\")\n",
        "            print(\"-\" * 60)\n",
        "        else:\n",
        "            print(\"  ❌ Could not generate markdown\")\n",
        "\n",
        "        # ============ SAVE SUMMARY ============\n",
        "        summary_file = doc_output_dir / f\"{pdf_path.stem}_summary.txt\"\n",
        "        with open(summary_file, 'w') as f:\n",
        "            f.write(f\"Document: {pdf_path.name}\\n\")\n",
        "            f.write(f\"Model: {config['model']}\\n\")\n",
        "            f.write(f\"Test Mode: {config['test_mode']}\\n\")\n",
        "            if config['test_mode']:\n",
        "                f.write(f\"Pages Processed: first {config['max_pages']}\\n\")\n",
        "            f.write(f\"\\nExtraction Results:\\n\")\n",
        "            f.write(f\"  Text Blocks: {len(extracted.text_blocks)}\\n\")\n",
        "            f.write(f\"  Tables: {len(extracted.tables)}\\n\")\n",
        "            f.write(f\"  Figures: {len(extracted.figures)}\\n\")\n",
        "            if config['cost_per_1k'] == 0:\n",
        "                f.write(f\"\\nCost: $0.00 (FREE model)\\n\")\n",
        "            else:\n",
        "                f.write(f\"\\nCost: ${vision_extractor.budget.total_cost_usd:.4f}\\n\")\n",
        "\n",
        "        print(f\"\\n✅ Summary saved to: {summary_file}\")\n",
        "\n",
        "        # ============ SAVE JSON (optional) ============\n",
        "        if hasattr(extracted, 'to_dict'):\n",
        "            json_path = doc_output_dir / f\"{pdf_path.stem}_data.json\"\n",
        "            with open(json_path, 'w', encoding='utf-8') as f:\n",
        "                json.dump(extracted.to_dict(), f, indent=2, ensure_ascii=False)\n",
        "            print(f\"✅ JSON data saved to: {json_path}\")\n",
        "\n",
        "        print(f\"\\n✅ All outputs saved to: {doc_output_dir}\")\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"\\n✗ Extraction failed: {e}\")\n",
        "        print(\"\\nCommon issues:\")\n",
        "        print(\"  - OPENROUTER_API_KEY not set or invalid\")\n",
        "        print(\"  - Rate limit exceeded for free model (wait a few minutes) \")\n",
        "        print(\"  - Network/API errors\")\n",
        "        if config['cost_per_1k'] == 0:\n",
        "            print(\"  - Free model daily limit reached (try again tomorrow)\")\n",
        "        extracted = None"
      ]
