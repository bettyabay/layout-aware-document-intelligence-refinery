        "uploaded = files.upload()\n",
        "\n",
        "# Define available classes\n",
        "classes = ['class_a', 'class_b', 'class_c', 'class_d']\n",
        "\n",
        "# Move each uploaded file to appropriate class folder\n",
        "for filename in uploaded.keys():\n",
        "    if filename.endswith('.pdf'):\n",
        "        print(f\"\\n📄 File: {filename}\")\n",
        "        print(\"Which class does this belong to?\")\n",
        "        print(\"Options: 1) class_a, 2) class_b, 3) class_c, 4) class_d\")\n",
        "\n",
        "        # Get user input\n",
        "        choice = input(\"Enter class number or name: \").strip()\n",
        "\n",
        "        # Map input to class name\n",
        "        if choice == '1' or choice.lower() == 'a' or choice.lower() == 'class_a':\n",
        "            dest_class = 'class_a'\n",
        "        elif choice == '2' or choice.lower() == 'b' or choice.lower() == 'class_b':\n",
        "            dest_class = 'class_b'\n",
        "        elif choice == '3' or choice.lower() == 'c' or choice.lower() == 'class_c':\n",
        "            dest_class = 'class_c'\n",
        "        elif choice == '4' or choice.lower() == 'd' or choice.lower() == 'class_d':\n",
        "            dest_class = 'class_d'\n",
        "        else:\n",
        "            dest_class = choice  # assume they typed full name\n",
        "\n",
        "        # Move the file\n",
        "        dest_path = f'/content/data/{dest_class}/{filename}'\n",
        "        shutil.move(filename, dest_path)\n",
        "        print(f\"✅ Moved to: {dest_path}\")\n",
        "\n",
        "# Show all uploaded files\n",
        "print(\"\\n📊 Uploaded PDFs:\")\n",
